{
  "buildCommand": "cd smart-room-twin/frontend && npm ci && npm run build",
  "outputDirectory": "smart-room-twin/frontend/dist",
  "installCommand": "cd smart-room-twin/frontend && npm ci",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/index.html",
      "status": 200
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 200
    }
  ]
}
